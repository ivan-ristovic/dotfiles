#!/bin/bash
# dotfiles-completion: begin
# commands: media-split
# body:
#   _arguments -s \
#     '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
#     '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_bin_helpers_dirs' \
#     '1:input media:_bin_helpers_media_files' \
#     '2:timestamps file:_bin_helpers_files' \
#     '*:ffmpeg argument:'
# dotfiles-completion: end

# shellcheck source=/dev/null
source "$(dirname -- "${BASH_SOURCE[0]}")/include" lib

function usage ()
{
    echo "usage: $(basename "$0") [--dry-run] [--output-dir dir] input_media timestamps_file [ffmpeg_args]"
    echo "timestamps file format (alternative 1):"
    echo "[HH:]MM:SS <title>"
    echo "[HH:]MM:SS <title>"
    echo "..."
    echo "timestamps file format (alternative 2):"
    echo "<title> [HH:]MM:SS"
    echo "<title> [HH:]MM:SS"
    echo "..."
    exit "${1:-1}"
}

SHLIB_DRY_RUN=false
output_dir=.

while [ $# -gt 0 ]; do
    case "$1" in
        -n | --dry-run)
            SHLIB_DRY_RUN=true
            ;;
        -o | --output-dir)
            [ $# -ge 2 ] || std_fat "$1 requires an output directory"
            output_dir=$2
            shift
            ;;
        -h | --help)
            usage 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            std_fat "unknown option: $1"
            ;;
        *)
            break
            ;;
    esac
    shift
done

export SHLIB_DRY_RUN

if [ $# -lt 2 ]; then
    usage
fi

cmd_require ffmpeg || exit 1

media=$1
ext="${media##*.}"
tsf=$2
shift 2

# read lines
mapfile -t ts < <(sed 's/^[[:space:]]*//;s/[[:space:]]*$//;/^$/d' "$tsf")

if [ "${#ts[@]}" -eq 0 ]; then
    std_fat "timestamps file is empty: $tsf"
fi

# test first line of the file to determine if ts is first or title
ts_first=false
if [[ "${ts[0]%% *}" =~ ^([0-9]{1,2}:)?[0-9]{1,2}:[0-9]{2}$ ]] ; then
    ts_first=true  
fi

cmd_run mkdir -p "$output_dir"

n=${#ts[@]}
for (( i=0; i<n; i++ )); do
    if $ts_first; then
        from="${ts[$i]%% *}"
        to="${ts[$((i+1))]%% *}"
        title="${ts[$i]#* }"
    else
        from="${ts[$i]##* }"
        to="${ts[$((i+1))]##* }"
        title="${ts[$i]% *}"
    fi

    title=$(str_sanitize_filename "$title")
    [ -n "$title" ] || title="segment-$((i+1))"
    name=$(fs_unique_path "$output_dir/$((i+1)) - $title.$ext") || exit 1

    echo "$from - ${to:-xx:xx} | $name"
    cmd=(ffmpeg -i "$media" -ss "$from")
    if [ -z "$to" ]; then
        :
    else
        cmd+=(-to "$to")
    fi
    cmd+=(-vcodec copy -acodec copy -y "$name")
    cmd+=("$@")
    cmd_run "${cmd[@]}"
done
