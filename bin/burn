#!/bin/bash

. include lib
export SHLIB_FMT_TIME=true

if [[ $# -lt 2 ]]; then
    log_msg "USB drives:"
    ls -lo /dev/disk/by-id/usb-*
    log_msg "Mountpoints:"
    lsblk
    std_usage "file.iso /dev/my-usb"
else
    iso=$1
    disk=$2
    if std_ask "Are you ABSOLUTELY SURE you want to burn '$iso' to '$disk'?"; then
        log_msg "Unmounting $disk"
        sudo umount "$disk"
        log_msg "Copying '$iso' to '$disk'"
        du -h "$iso"
        sudo dd bs=4M if="$iso" of="$disk" conv=fsync oflag=direct status=progress || std_fat "Copying errored"
        log_msg "Ensuring buffers are written..."
        sudo sync
        log_suc "Done!"
    fi
fi

