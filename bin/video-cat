#!/bin/bash
# dotfiles-completion: begin
# commands: video-cat
# body:
#   _arguments '*:input video:_bin_helpers_video_files'
# dotfiles-completion: end


if [ $# -lt 2 ]; then
    echo "usage: $(basename $0) input_video ..."
    exit 1
fi

output="merged.mp4"
i=1
while [ -f "$output" ]; do
    output="merged_${i}.mp4"
    i=$((i+1))
done

concat_list=$(mktemp) || exit 1
cleanup() {
    rm -f "$concat_list"
}
trap cleanup EXIT

for f in "$@"; do
    path=$(realpath -- "$f") || exit 1
    escaped=$(printf '%s' "$path" | sed "s/'/'\\\\''/g")
    printf "file '%s'\n" "$escaped" >> "$concat_list"
done

set -xe;
ffmpeg -f concat -safe 0 -i "$concat_list" -c copy "$output"
