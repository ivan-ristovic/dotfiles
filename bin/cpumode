#!/bin/bash
# dotfiles-completion: begin
# commands: cpumode cpumode-amd cpumode-intel
# body:
#   _arguments -s \
#     '(-M --maximum)'{-M,--maximum}'[performance mode]' \
#     '(-m --minimum)'{-m,--minimum}'[powersave mode]' \
#     '(-a --auto)'{-a,--auto}'[automatic governor]' \
#     '(-b --boost)'{-b,--boost}'[toggle or set CPU boost]::state:(on off yes no 1 0)' \
#     '(-c --conservative)'{-c,--conservative}'[conservative governor]' \
#     '(-s --schedutil)'{-s,--schedutil}'[schedutil governor]' \
#     '(-u --userspace)'{-u,--userspace}'[set userspace CPU frequency]:frequency:_bin_helpers_cpu_freqs' \
#     '(-l --load)'{-l,--load}'[load CPU powersave driver]' \
#     '(-n --now)'{-n,--now}'[show current mode]' \
#     '(-S --set)'{-S,--set}'[set maximum CPU frequency]:frequency:_bin_helpers_cpu_freqs' \
#     '(-r --reset)'{-r,--reset}'[reset maximum CPU frequency]' \
#     '(-f --frequencies)'{-f,--frequencies}'[show available frequencies]' \
#     '(-t --time)'{-t,--time}'[show time spent in CPU states]' \
#     '(-v --version)'{-v,--version}'[show version]' \
#     '(-h --help)'{-h,--help}'[show help]'
# dotfiles-completion: end


set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
vendor=${CPUMODE_VENDOR:-}

if [ -z "$vendor" ] && [ -r /proc/cpuinfo ]; then
	vendor=$(awk -F: '
		/^vendor_id[[:space:]]*:/ {
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
			print $2
			exit
		}
	' /proc/cpuinfo)
fi

case "$vendor" in
	GenuineIntel)
		backend=cpumode-intel
		;;
	AuthenticAMD)
		backend=cpumode-amd
		;;
	*)
		if [ -n "$vendor" ]; then
			printf 'error: unsupported CPU vendor: %s\n' "$vendor" >&2
		else
			printf 'error: unable to detect CPU vendor\n' >&2
		fi
		exit 1
		;;
esac

exec "$script_dir/$backend" "$@"
