#!/bin/bash
# dotfiles-completion: begin
# commands: myip
# body:
#   _arguments '1:IP version:(4 6)'
# dotfiles-completion: end


# shellcheck source=bin/include
source "$(dirname -- "${BASH_SOURCE[0]}")/include" lib

resolver=("@resolver1.opendns.com")
version=""
version_arg=()

cmd_require dig || exit 1

if [ $# -gt 0 ]; then
    version=$1
fi

if [ -n "$version" ]; then
    if [ "$version" == "4" ]; then
        resolver=("@resolver4.opendns.com")
    elif [ "$version" == "6" ]; then
        resolver=("@resolver1.ipv6-sandbox.opendns.com" AAAA)
    else
        echo "usage: $0 [4|6]"
        exit 1
    fi
    version_arg=(-"$version")
fi

dig +short "${resolver[@]}" myip.opendns.com "${version_arg[@]}"
