#!/bin/bash
# dotfiles-completion: begin
# commands: ssh-copy-pub-key
# body:
#   _arguments \
#     '1:public key or host:_alternative "public-keys:public key:_bin_helpers_pub_keys" "hosts:host:_hosts"' \
#     '2:host:_hosts'
# dotfiles-completion: end


# shellcheck source=/dev/null
source "$(dirname -- "${BASH_SOURCE[0]}")/include" lib

assert_argc_ge $# 1 "[path/to/pub/key] user@server"

function get_key_path () 
{
    echo "${1:-$HOME/.ssh/id.pub}"
}

if [ $# -ge 2 ]; then
    dst="$2"
    key=$(get_key_path "$1")
else
    dst="$1"
    key=$(get_key_path)
fi

set -e;
ssh-copy-id -i "$key" "$dst"
log_suc "Done!"
