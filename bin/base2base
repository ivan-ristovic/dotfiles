#!/bin/bash
# dotfiles-completion: begin
# commands: base2base
# body:
#   _arguments \
#     '1:input base:(2 8 10 16)' \
#     '2:output base:(2 8 10 16)' \
#     '*:number:'
# dotfiles-completion: end


# shellcheck source=bin/include
source "$(dirname -- "${BASH_SOURCE[0]}")/include" lib

assert_argc_ge $# 3 "base_from base_to num [nums ...]"

ibase=$1
obase=$2
shift 2
nums=$(str_join ';' "$@" | tr '[:lower:]' '[:upper:]')

# Order matters! As soon as ibase is set, input must be in that base
bc <<< "obase=$obase;ibase=$ibase;$nums"
