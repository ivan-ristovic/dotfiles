#!/bin/bash
# dotfiles-completion: begin
# commands: light-theme
# body:
#   _arguments \
#     '1:command:_command_names -e' \
#     '*:argument:_files'
# dotfiles-completion: end


function usage ()
{
    echo -e "usage: $0 [--shell|-s] <target>"
    exit 2
}

if [ $# -lt 1 ]; then
    usage
fi

QT_STYLE_OVERRIDE=Fusion GTK_THEME=KvArc "$@"
