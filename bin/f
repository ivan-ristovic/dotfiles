#!/usr/bin/env bash
# dotfiles-completion: begin
# commands: f fa ff ffa mpp
# body:
#   _message -e query 'search query'
# dotfiles-completion: end


# Two-phase filtering with fd and fzf
# 1. Search for files using fd
# 2. Interactively restart fd with reload action
#    * Press alt-enter to switch to fzf-only filtering
# 3. Preview matches
# Switch between fd mode and fzf filtering mode (CTRL-T)

set -euo pipefail

# shellcheck source=bin/include
source "$(dirname -- "${BASH_SOURCE[0]}")/include" lib

cmd_require fd fzf || exit 1

tmp_dir=$(fs_tempdir fd-fzf) || exit 1
fd_query_file=$tmp_dir/fd-query
fzf_query_file=$tmp_dir/fzf-query
fd_query_ref=$(printf '%q' "$fd_query_file")
fzf_query_ref=$(printf '%q' "$fzf_query_file")
cleanup() {
    rm -rf -- "$tmp_dir"
}
trap cleanup EXIT

FD_OPTS=${FD_OPTS:-""}
FD_PREFIX="fd $FD_OPTS"
INITIAL_QUERY="${*:-}"
: | fzf --ansi --disabled --query "$INITIAL_QUERY" \
    --bind "start:reload:$FD_PREFIX {q}" \
    --bind "change:reload:sleep 0.1; $FD_PREFIX {q} || true" \
    --bind 'ctrl-t:transform:[[ ! $FZF_PROMPT =~ fd ]] &&
      echo "rebind(change)+change-prompt(1. fd> )+disable-search+transform-query:echo \{q} > '"$fd_query_ref"'; cat '"$fzf_query_ref"'" ||
      echo "unbind(change)+change-prompt(2. fzf> )+enable-search+transform-query:echo \{q} > '"$fzf_query_ref"'; cat '"$fd_query_ref"'"' \
    --color "hl:-1:underline,hl+:-1:underline:reverse" \
    --prompt '[Ctrl+T to swap] 1. fd> ' \
    --delimiter : \
    --preview 'preview {1}' \
    --preview-window 'up,60%,border-bottom' \
    --bind "enter:become($EDITOR {1})"
