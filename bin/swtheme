#!/bin/bash
# dotfiles-completion: begin
# commands: swtheme
# body:
#   _arguments '1:theme:_bin_helpers_themes'
# dotfiles-completion: end


SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
THEMES_DIR="$SCRIPT_DIR/../dotfiles/themes/"

if [ ! -d "$THEMES_DIR" ]; then
    echo "fatal: dotfiles/themes directory is not present"
    exit 1
fi

pushd "$THEMES_DIR" || exit 1

function usage () 
{
    if [ $# -eq 0 ]; then
        echo "Missing theme to apply."
    else
        echo "$@"
    fi
    echo "Available themes:"
    ls -l .
    popd || exit
    exit 1
}

if [ $# -ne 1 ]; then
    usage
fi

theme=("$1"*/)
if [ "${#theme[@]}" -ne 1 ]; then
    usage "Unique theme name starting with $1 was not found." 
fi

rm -f current
ln -s "${theme[0]}" current
./postswitch
popd || exit
