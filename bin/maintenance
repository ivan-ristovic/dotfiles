#!/bin/bash
# dotfiles-completion: begin
# commands: maintenance
# body:
#   _bin_helpers_no_args
# dotfiles-completion: end


. include lib
SHLIB_FMT_TIME=true

function prompt () 
{
    std_confirm log_msg "$*"
}

prompt "List systemd errors:"
log_exec systemctl --failed

prompt "List systemd error logs:"
journalctl -p 3 -b | less

prompt "Check package diffs:"
list_loc=$NC_BACKUP/package_list_$(hostname).txt
touch $list_loc
if ! diff -u <(cat $list_loc) <(pacman -Qqe) ; then
    log_msg "Changes detected. Check whether install lists should be updated."
    if std_ask "Update the backed up package list?" ; then
        mv $list_loc $list_loc.bak
        if pacman -Qqe > $list_loc ; then
            log_suc "Package list updated"
        else
            log_err "Failed to update package list"
        fi
    fi
fi
unset list_loc
log_suc "Package diffs processed."

prompt "Update packages (official)"
log_exec sudo pacman -Syu

prompt "Update packages (AUR)"
log_exec yay -Syu

prompt "Show orphaned packages"
log_exec pacman -Qtd

prompt "Show foreign packages"
log_exec pacman -Qm

prompt "Cleaning package manager caches"
log_exec paccache -r
log_exec yaycache -r

prompt "Checking for .pacnew files"
log_exec sudo pacdiff

log_suc "Done. Have a nice day."

