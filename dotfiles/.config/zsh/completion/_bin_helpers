    _message -e themes 'theme name'
  fi
}

_bin_helpers_tmux_layouts() {
  local layouts_dir=$HOME/.tmux/layouts
  local -a layouts
  layouts=( ${layouts_dir}/*(N.:t) )
  if (( $#layouts )); then
    _describe -t tmux-layouts 'layout' layouts
  else
    _message -e tmux-layouts 'layout name'
  fi
}

_bin_helpers_no_args() {
  _message -e arguments 'no arguments'
}

_bin_helpers() {
  emulate -L zsh
  setopt extendedglob nullglob

  local cmd=${service:-${words[1]}}

  case $cmd in
    7z-backup)
      _arguments '1:directory:_bin_helpers_dirs'
      ;;
    7z-restore)
      _arguments '1:backup archive:_bin_helpers_archives'
      ;;
    ask)
      _message -e prompt 'prompt text'
      ;;
    base2base)
      _arguments \
        '1:input base:(2 8 10 16)' \
        '2:output base:(2 8 10 16)' \
        '*:number:'
      ;;
    beep)
      _arguments \
        '1:frequency:' \
        '2:duration seconds:'
      ;;
    burn)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing device]' \
        '1:ISO image:_bin_helpers_iso_files' \
        '2:block device:_bin_helpers_block_devices'
      ;;
    calc)
      _message -e expression 'calculator expression'
      ;;
    colorconv)
      _arguments \
        '1:hex color or red channel:' \
        '2:green channel:' \
        '3:blue channel:'
      ;;
    colorconv-term)
      _arguments '1:hex color:'
      ;;
    conn)
      _arguments \
        '1:server id:_bin_helpers_conn_ids' \
        '2:protocol:(ssh mosh scp sftp telnet nc)'
      ;;
    cpu)
      local -a freqs boost

      if [[ -r /sys/devices/system/cpu/cpufreq/policy0/scaling_available_frequencies ]]; then
          freqs=(${(f)"$(</sys/devices/system/cpu/cpufreq/policy0/scaling_available_frequencies)"})
      else
          freqs=(
              25% 50% 75% 90% 100%
              800MHz 1GHz 1.5GHz 2GHz 2.5GHz 3GHz
          )
      fi

      boost=(toggle on off)

      _arguments \
          '(-P -B -S -A --fixed)'{-P,--performance}'[performance profile]' \
          '(-P -B -S -A --fixed)'{-B,--balanced}'[balanced profile]' \
          '(-P -B -S -A --fixed)'{-S,--powersave}'[powersave profile]' \
          '(-P -B -S -A --fixed)'{-A,--auto}'[automatic/default profile]' \
          '(-P -B -S -A --fixed)--fixed=[set fixed CPU frequency]:frequency:(${freqs})' \
          '--min=[minimum CPU frequency]:frequency:(${freqs})' \
          '--max=[maximum CPU frequency]:frequency:(${freqs})' \
          '(-r --reset)'{-r,--reset}'[reset frequency limits]' \
          '(-b --boost)'{-b,--boost}'[toggle or set boost]:boost mode:(${boost})' \
          '(-f --frequencies)'{-f,--frequencies}'[list supported frequencies]' \
          '(-s --status)'{-s,--status}'[show current status]' \
          '(-t --time)'{-t,--time}'[show residency statistics]' \
          '(-v --verbose)'{-v,--verbose}'[verbose/debug output]' \
          '(-c --clean)'{-c,--clean}'[disable colored output]' \
          '(-h --help)'{-h,--help}'[show help]'
      ;;
    crypto)
      _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[enable debug output]' \
        '(-c --cleanup)'{-c,--cleanup}'[clean up temporary files and exit]' \
        '(-t --torify)'{-t,--torify}'[request data via Tor]' \
        '(-w --verbose)'{-w,--verbose}'[show verbose output]' \
        '(-n --top)'{-n,--top}'[number of currencies to display]:count:' \
        '(-p --depth)'{-p,--depth}'[search depth for symbol lists]:count:' \
        '(-f --fiat)'{-f,--fiat}'[currency used for prices]:currency:_bin_helpers_fiat_currencies' \
        '(-e --eur)'{-e,--eur}'[use EUR as currency]' \
        '(-l --listbysymbols)'{-l,--listbysymbols}'[comma-separated crypto symbols]:symbols:_bin_helpers_crypto_symbols' \
        '(-i --listbynames)'{-i,--listbynames}'[comma-separated crypto names]:names:_bin_helpers_crypto_names'
      ;;
    dlpage)
      _arguments '*:URL:_urls'
      ;;
    dlsubs)
      _arguments -s \
        '--cli[force CLI mode]' \
        '(-g --gui)'{-g,--gui}'[select GUI]:gui:(auto kde gnome cli)' \
        '(-u --username)'{-u,--username}'[OpenSubtitles username]:username:' \
        '(-p --password)'{-p,--password}'[OpenSubtitles password]:password:' \
        '(-l --lang)'{-l,--lang}'[subtitle language list]:languages:' \
        '(-s --search)'{-s,--search}'[search mode]:mode:(hash filename hash_then_filename hash_and_filename)' \
        '(-t --select)'{-t,--select}'[selection mode]:mode:(manual default auto)' \
        '(-a --auto)'{-a,--auto}'[select and download best subtitles automatically]' \
        '(-i --skip)'{-i,--skip}'[skip files with existing subtitles]' \
        '(-o --output)'{-o,--output}'[subtitle output directory]:directory:_bin_helpers_dirs' \
        '(-x --suffix)'{-x,--suffix}'[force language code suffix]' \
        '--noai[ignore AI or machine translated subtitles]' \
        '--nohi[ignore hearing-impaired subtitles]' \
        '*:video file or directory:_bin_helpers_video_or_dir'
      ;;
    f|fa|ff|ffa|mpp)
      _message -e query 'search query'
      ;;
    flac2mp3)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '*:FLAC file or directory:_bin_helpers_flac_or_dir'
      ;;
    image-alpha)
      _arguments -s \
        '-f[fuzz percent]:fuzz:(0 5 10 15 20 25)' \
        '-s[use speedy antialiasing]' \
        '-S[suppress antialiasing]' \
        '-A[suppress antialiasing]' \
        '-h[show help]' \
        '-p[floodfill pixel coordinate]:x,y:' \
        '-v[verbose output]' \
        '*:image file:_bin_helpers_image_files'
      ;;
    image-opt)
      _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-S --no-strip)'{-S,--no-strip}'[do not strip EXIF metadata]' \
        '(-q --quality)'{-q,--quality}'[JPEG quality percent]:quality:(100 95 90 85 80 75 70 60)' \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '(-e --error)'{-e,--error}'[halt on ImageMagick error]' \
        '1:image file or input directory:_bin_helpers_image_or_dir' \
        '2:output directory:_bin_helpers_dirs'
      ;;
    include)
      _arguments '1:library:_bin_helpers_shlib_names'
      ;;
    joinby)
      _arguments \
        '1:separator:' \
        '*:item:'
      ;;
    kbl-lenovo)
      local effect=${words[2]}
      local -a effects

      if (( CURRENT == 2 )); then
        effects=(
          'static:Static color'
          'breath:Fade light in and out'
          'hue:Transition across hue circle'
          'wave:Rainbow wave'
          'off:Turn light off'
        )
        _describe -t effects 'effect' effects
        return
      fi

      case $effect in
        static)
          _arguments -s \
            '(-b --brightness)'{-b,--brightness}'[brightness]:level:(1 2)' \
            '*:hex color:_bin_helpers_hex_colors'
          ;;
        breath)
          _arguments -s \
            '(-b --brightness)'{-b,--brightness}'[brightness]:level:(1 2)' \
            '(-s --speed)'{-s,--speed}'[animation speed]:speed:(1 2 3 4)' \
            '*:hex color:_bin_helpers_hex_colors'
          ;;
        hue)
          _arguments -s \
            '(-b --brightness)'{-b,--brightness}'[brightness]:level:(1 2)' \
            '(-s --speed)'{-s,--speed}'[animation speed]:speed:(1 2 3 4)'
          ;;
        wave)
          _arguments -s \
            '(-b --brightness)'{-b,--brightness}'[brightness]:level:(1 2)' \
            '(-s --speed)'{-s,--speed}'[animation speed]:speed:(1 2 3 4)' \
            '(-d --direction)'{-d,--direction}'[wave direction]:direction:(ltr rtl)'
          ;;
        off)
          _bin_helpers_no_args
          ;;
        *)
          _message -e effects 'effect'
          ;;
      esac
      ;;
    light-theme)
      _arguments \
        '1:command:_command_names -e' \
        '*:argument:_files'
      ;;
    maintenance)
      _bin_helpers_no_args
      ;;
    media-split)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_bin_helpers_dirs' \
        '1:input media:_bin_helpers_media_files' \
        '2:timestamps file:_bin_helpers_files' \
        '*:ffmpeg argument:'
      ;;
    mp3gain-all)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '*:MP3 file or directory:_bin_helpers_mp3_or_dir'
      ;;
    myip)
      _arguments '1:IP version:(4 6)'
      ;;
    o)
      _arguments -s \
        '(-s --shell)'{-s,--shell}'[use shell action instead of xdg-open]' \
        '*:target:_files'
      ;;
    palette)
      _bin_helpers_no_args
      ;;
    pathfind)
      _arguments '1:command name pattern:_command_names -e'
      ;;
    preview)
      _arguments '1:file:_bin_helpers_files'
      ;;
    qr)
      _arguments -s \
        '(-r --read-from)'{-r,--read-from}'[read payload bytes from file]:file:_bin_helpers_files' \
        '(-l --level)'{-l,--level}'[error correction level]:level:(L M Q H)' \
        '(-m --margin)'{-m,--margin}'[quiet-zone margin]:modules:' \
        '--full[render modules as full-height cells]' \
        '--plain[render without ANSI colors]' \
        '*:text:'
      ;;
    randpass)
      _arguments -s \
        '-h[show help]' \
        '-\?[show help]' \
        '-g[use graph characters]' \
        '-a[use alphabetic characters]' \
        '-f[legacy flag]' \
        '-n[password length]:length:(8 12 16 20 24 32 48 64)'
      ;;
    shlib)
      _arguments \
        '1:function name:' \
        '*:argument:'
      ;;
    speedtest)
      _bin_helpers_no_args
      ;;
    ssh-copy-pub-key)
      _arguments \
        '1:public key or host:_alternative "public-keys:public key:_bin_helpers_pub_keys" "hosts:host:_hosts"' \
        '2:host:_hosts'
      ;;
    swtheme)
      _arguments '1:theme:_bin_helpers_themes'
      ;;
    timer)
      _arguments -s \
        '-r[repeat timer]:rounds:' \
        '-d[delay timer start]:seconds:' \
        '-q[suppress command-line output]' \
        '-N[suppress desktop notifications]' \
        '-p[write to /tmp/timer.fifo]' \
        '-h[show help]' \
        '-v[show version]' \
        '*:duration:'
      ;;
    treed)
      _arguments '*:directory:_bin_helpers_dirs'
      ;;
    tx)
      _arguments \
        '1:layout:_bin_helpers_tmux_layouts' \
        '2:root directory:_bin_helpers_dirs'
      ;;
    tz)
      _bin_helpers_no_args
      ;;
    video-cat)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '(-o --output)'{-o,--output}'[output video]:output file:_files' \
        '*:input video:_bin_helpers_video_files'
      ;;
    video-conv)
      _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-c --codec)'{-c,--codec}'[video codec suffix passed as lib<codec>]:codec:(x264 x265 vpx vp9 aom-av1 svtav1)' \
        '(-t --tag)'{-t,--tag}'[video tag]:tag:(hvc1 avc1 mp4v)' \
        '(-f --format)'{-f,--format}'[output format]:format:(mp4 mkv webm mov)' \
        '(-s --scale)'{-s,--scale}'[output height]:height:(2160 1440 1080 720 480 360)' \
        '(-a --aspect)'{-a,--aspect}'[aspect ratio]:ratio:(16/9 4/3 1/1 21/9)' \
        '(-q --quality)'{-q,--quality}'[CRF quality]:crf:(18 20 23 28)' \
        '(-p --preset)'{-p,--preset}'[encoder preset]:preset:(ultrafast superfast veryfast faster fast medium slow slower veryslow)' \
        '(-A --audio-stream)'{-A,--audio-stream}'[audio stream index]:index:(0 1 2 3)' \
        '(-C --copy-audio)'{-C,--copy-audio}'[copy audio stream]' \
        '(-v --verbose)'{-v,--verbose}'[show ffmpeg output]' \
        '--subs[include subtitles]' \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '(-l --log)'{-l,--log}'[log ffmpeg output]' \
        '(-e --error)'{-e,--error}'[halt on ffmpeg error]' \
        '1:video file or input directory:_bin_helpers_video_or_dir' \
        '2:output directory:_bin_helpers_dirs'
      ;;
    video-cut)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '(-o --output)'{-o,--output}'[output video]:output file:_files' \
        '1:input video:_bin_helpers_video_files' \
        '2:start timestamp:' \
        '3:end timestamp:'
      ;;
    video-track-merge)
      _arguments -s \
        '(-n --dry-run)'{-n,--dry-run}'[print commands without writing files]' \
        '1:input video:_bin_helpers_video_files' \
        '2:output video:_files'
      ;;
    wf)
      _message -e location 'weather location'
      ;;
    wifi-restart)
      _bin_helpers_no_args
      ;;
    ytdl-mp3)
      _arguments '*:URL:_urls'
      ;;
    *)
      _normal
      ;;
  esac
}

if [[ $funcstack[1] == _bin_helpers ]]; then
  _bin_helpers "$@"
fi
