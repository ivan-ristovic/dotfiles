_bin_helpers_hex_colors() {
  compadd 000000 ffffff ff0000 00ff00 0000ff ffff00 ff00ff 00ffff
}

_bin_helpers_pub_keys() {
  local -a keys
  keys=( "$HOME"/.ssh/*.pub(N) )
  if (( $#keys )); then
    compadd -a keys
  else
    _files -g '*.pub(-.)'
  fi
}

_bin_helpers_shlib_names() {
  local root=${SHLIB_ROOT:-$HOME/dotfiles/shlib/lib}
  local -a libs
  libs=( ${root}/*.sh(N:t:r) )
  if (( $#libs )); then
    _describe -t shlib-libraries 'library' libs
  else
    _message -e shlib-libraries 'library name'
  fi
}

_bin_helpers_themes() {
  local themes_dir=$HOME/dotfiles/dotfiles/themes
  local -a themes
  themes=( ${themes_dir}/*(N/:t) )
  if (( $#themes )); then
    _describe -t themes 'theme' themes
