_bin_helpers_block_devices() {
  local -a devs
  devs=( /dev/disk/by-id/usb-*(N) /dev/sd[a-z](N) /dev/nvme[0-9]n[0-9](N) )
  if (( $#devs )); then
    compadd -a devs
  else
    _files -W /dev
  fi
}

_bin_helpers_conn_ids() {
  local line ids_raw id
  local -a ids

  if [[ -r $HOME/.known_hosts ]]; then
    while IFS= read -r line; do
      line=${line##[[:space:]]##}
      [[ -z $line || $line == \#* ]] && continue
      ids_raw=${line%%[[:space:]]*}
      for id in ${(s:,:)ids_raw}; do
        [[ -n $id ]] && ids+=( "$id" )
      done
    done < "$HOME/.known_hosts"
  fi

  ids=( ${(u)ids} )
  if (( $#ids )); then
    _describe -t server-ids 'server id' ids
  else
    _hosts
  fi
}

_bin_helpers_cpu_freqs() {
  local freq_file=/sys/devices/system/cpu/cpu0/cpufreq/scaling_available_frequencies
  local contents
  local -a freqs

  if [[ -r $freq_file ]]; then
    contents=$(< "$freq_file")
    freqs=( ${(z)contents} )
  fi

  if (( $#freqs )); then
    _describe -t cpu-frequencies 'CPU frequency' freqs
  else
    _message -e cpu-frequency 'frequency in kHz'
  fi
}

_bin_helpers_fiat_currencies() {
  local -a currencies=(
