}

_bin_helpers_crypto_symbols() {
  local -a symbols=(btc eth usdt xrp bch bnb dot link ltc sol ada doge xmr xlm etc)
  _values -s , 'crypto symbol' ${symbols[@]}
}

_bin_helpers_crypto_names() {
