'''


class CompletionBlock:
    def __init__(self, path, commands, body):
        self.path = path
        self.commands = commands
        self.body = body


def collect_bin_files():
    paths = set()

    result = subprocess.run(
        ["git", "ls-files", "-z", "bin"],
        cwd=ROOT,
        check=True,
        stdout=subprocess.PIPE,
    )
    paths.update(
        ROOT / item.decode()
        for item in result.stdout.split(b"\0")
        if item
    )

    bin_dir = ROOT / "bin"
    paths.update(path for path in bin_dir.iterdir() if path.is_file())

    return sorted(paths)


def is_executable_file(path):
    try:
        mode = path.stat().st_mode
    except FileNotFoundError:
        return False
    return stat.S_ISREG(mode) and bool(mode & (stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH))


def strip_comment(line):
    stripped = line.lstrip()
    if not stripped.startswith("#"):
        return None
    text = stripped[1:]
    if text.startswith(" "):
        text = text[1:]
    return text.rstrip("\n")


def dedent_body(lines):
    non_empty = [line for line in lines if line.strip()]
    if not non_empty:
        return []
    indent = min(len(line) - len(line.lstrip(" ")) for line in non_empty)
    return [line[indent:] if len(line) >= indent else "" for line in lines]


def parse_completion_metadata(path):
    text = path.read_text()
    lines = text.splitlines()
    blocks = []
    has_none = False
    index = 0

    while index < len(lines):
        comment = strip_comment(lines[index])
        if comment == "dotfiles-completion: none":
            has_none = True
            index += 1
            continue
        if comment != "dotfiles-completion: begin":
            index += 1
            continue

        index += 1
        commands = None
        body = []
        in_body = False
        while index < len(lines):
            comment = strip_comment(lines[index])
            if comment is None:
                raise ValueError(f"{path}: non-comment line inside completion metadata")
            if comment == "dotfiles-completion: end":
                break
            if in_body:
                body.append(comment)
            elif comment.startswith("commands:"):
                commands = comment.removeprefix("commands:").split()
            elif comment == "body:":
                in_body = True
            elif not comment:
                pass
            else:
                raise ValueError(f"{path}: unknown completion metadata line: {comment}")
            index += 1
        else:
            raise ValueError(f"{path}: unterminated completion metadata block")

        if not commands:
            raise ValueError(f"{path}: completion metadata is missing commands")
        body = dedent_body(body)
        if not body:
            raise ValueError(f"{path}: completion metadata has an empty body")
        blocks.append(CompletionBlock(path, commands, body))
        index += 1

    if has_none and blocks:
        raise ValueError(f"{path}: cannot combine completion metadata with dotfiles-completion: none")
    return blocks, has_none


def collect_blocks():
    paths = [path for path in collect_bin_files() if is_executable_file(path)]
    missing = []
    command_sources = {}
    blocks = []
    records = []

    for path in paths:
        parsed_blocks, has_none = parse_completion_metadata(path)
        records.append((path, parsed_blocks, has_none))
        for block in parsed_blocks:
            blocks.append(block)
            for command in block.commands:
                source = command_sources.setdefault(command, block.path)
                if source != block.path:
                    raise ValueError(
                        f"{path}: command '{command}' is already defined by {source.relative_to(ROOT)}"
                    )

    covered_commands = set(command_sources)
    for path, parsed_blocks, has_none in records:
        if parsed_blocks or has_none or path.name in covered_commands:
            continue
        missing.append(path.relative_to(ROOT).as_posix())

    return sorted(blocks, key=lambda block: block.commands[0]), missing


def render_completion(blocks):
    commands = sorted(command for block in blocks for command in block.commands)
    out = []
    # out.append("# Generated by dotfiles/.utils/gen-bin-helper-completions. Do not edit directly.")
    out.append("#compdef " + " ".join(commands))
    out.append("")
    out.append(PRELUDE.rstrip())
    out.append("")
    out.append("_bin_helpers() {")
    out.append("  emulate -L zsh")
    out.append("  setopt extendedglob nullglob")
    out.append("")
    out.append("  local cmd=${service:-${words[1]}}")
    out.append("")
    out.append("  case $cmd in")
    for block in blocks:
        out.append(f"    {'|'.join(block.commands)})")
        for line in block.body:
            out.append("      " + line if line else "")
        out.append("      ;;")
    out.append("    *)")
    out.append("      _normal")
    out.append("      ;;")
    out.append("  esac")
    out.append("}")
    out.append("")
    out.append("if [[ $funcstack[1] == _bin_helpers ]]; then")
    out.append('  _bin_helpers "$@"')
    out.append("fi")
    out.append("")
    return "\n".join(out)


def main():
    parser = argparse.ArgumentParser(description="Generate zsh completions for dotfiles bin helpers")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--write", action="store_true", help="write generated completion file")
    mode.add_argument("--check", action="store_true", help="fail if completion file is stale")
    args = parser.parse_args()

    try:
        blocks, missing = collect_blocks()
        generated = render_completion(blocks)
    except ValueError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    for path in missing:
        print(f"warning: missing completion metadata: {path}", file=sys.stderr)

    if args.write:
        OUTPUT_FILE.write_text(generated)
        return 0

    if args.check:
        current = OUTPUT_FILE.read_text() if OUTPUT_FILE.exists() else ""
        if current != generated:
            diff = difflib.unified_diff(
                current.splitlines(keepends=True),
                generated.splitlines(keepends=True),
                fromfile=str(OUTPUT_FILE.relative_to(ROOT)),
                tofile="generated",
            )
            sys.stderr.writelines(diff)
            return 1
        return 0

    sys.stdout.write(generated)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
