#!/bin/bash

if [ "$EUID" -eq 0 ]; then 
    echo "Running as root is disallowed."
    exit 1
fi

DOTFILES_ROOT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P) || exit 1
cd "$DOTFILES_ROOT_DIR" || exit 1

# Check for dotfiles root
GIT_DIR=$(grep -E 'ivan(-ristovic)?/dotfiles' .git/config)
if [ -z "$GIT_DIR" ]; then
    echo "Not in dotfiles directory. Exiting ..."
    exit 1
fi

# Check if core dirs are present
required_dirs=("shlib" "dotfiles" "install" "patches" "systemd")
for dir in "${required_dirs[@]}"; do
    if [ ! -d "$dir" ]; then
        echo "$dir/ directory is not present. Exiting ..."
        exit 1
    fi
done
unset required_dirs

# Init tracked submodules
uninitialized_submodules=()
while IFS= read -r submodule_path; do
    uninitialized_submodules+=("$submodule_path")
done < <(git submodule status --recursive 2> /dev/null | awk '/^-/ { print $2 }')

if [ "${#uninitialized_submodules[@]}" -gt 0 ]; then
    echo "Submodule(s) not initialized. Initializing..."
    git submodule update --init --recursive -- "${uninitialized_submodules[@]}"
fi
unset uninitialized_submodules

# Load utils
export SHLIB_ROOT="$PWD/shlib/lib"
# shellcheck source=utils.sh
source "utils.sh"


function usage ()
{
    local exit_code=${1:-2}
    echo -e "usage: $0"
    echo -e "\t[--user username | -u username]"
    echo -e "\t[--dotfiles | --packages install_list_path | --patch[es] --services | --complete]"
    echo -e "\t[--verbose | -v] [--strict | -s]"
    echo -e "\t[--log  | -l]"
    echo -e "\t[--help | -h]"
    echo -e "\t[--dry[-run] | -d]"
    echo
    echo "  LEGEND:"
    echo -e "\t--help -h             prints this manual"
    echo -e "\t--strict -s           halt on error (set -e)"
    echo -e "\t--repair -r           repair dotfile symlinks"
    echo -e "\t--verbose -v          runs the script in debug mode (set -x)"
    echo -e "\t--remote              update git remote URL"
    echo -e "\t--log -l              output log to logfile"
    echo -e "\t--dry[-run] -d        dry run"
    echo
    echo -e "\t--dotfiles            link dotfiles (default)"
    echo -e "\t--packages --install  install packages from the given install list"
    echo -e "\t--patch --patches     perform patches"
    echo -e "\t--complete --all      perform all of the above"
    exit "$exit_code"
}


GIT_REMOTE="git@github.com:ivan-ristovic/dotfiles.git"

STOW_EXTRA_ARGS=()
SETUP_SCRIPT_EXTRA_ARGS=()
SETUP_OVERRIDE=false
SETUP_DOTFILES=false
SETUP_PACKAGES=false
SETUP_PATCHES=false
SETUP_SERVICES=false
DRY_RUN=false
SETUP_FAILED=false
SETUP_USER=${SUDO_USER:-$(logname 2> /dev/null)}
SETUP_HOME_DIR="/home/$SETUP_USER"

SHORT_OPTS=v,s,u:,h,l,r,d
LONG_OPTS=user:,username:,dotfiles,link,stow,packages,install,dotfiles,patch,patches,services,all,complete,help,strict,repair,debug,verbose,remote,git,log,dry,dry-run
if ! OPTS=$(getopt --alternative --name 'argument error' --options $SHORT_OPTS --longoptions $LONG_OPTS -- "$@"); then
    std_fat "failed to parse provided arguments"
fi
eval set -- "$OPTS"

while :
do
    case "$1" in
        --all | --complete)
            SETUP_OVERRIDE=true
            SETUP_DOTFILES=true
            SETUP_PACKAGES=true
            SETUP_PATCHES=true
            SETUP_SERVICES=true
            ;;
        --packages | --install)
            SETUP_OVERRIDE=true
            SETUP_PACKAGES=true
            ;;
        --dotfiles | --link | --stow)
            SETUP_OVERRIDE=true
            SETUP_DOTFILES=true
            ;;
        --patch | --patches)
            SETUP_OVERRIDE=true
            SETUP_PATCHES=true
            ;;
        --services)
            SETUP_OVERRIDE=true
            SETUP_SERVICES=true
            ;;
        --remote | --git)
            if {
                if git remote get-url origin > /dev/null 2>&1; then
                    git remote set-url origin "$GIT_REMOTE"
                else
                    git remote add origin "$GIT_REMOTE"
                fi
            }; then
                log_suc "Successfully updated remote: $GIT_REMOTE"
                exit 0
            else 
                log_err "Failed to update remote"
                exit 1
            fi
            ;;
        -l | --log)
            logfile="setup-$(date +%s).log"
            log_msg "logging output to: $logfile"
            exec 1> >(tee -a "$logfile")
            exec 2>&1
            ;;
        -v | --verbose | --debug)
            log_msg "debug mode enabled"
            set -x; 
            ;;
        -r | --repair)
            log_msg "repairing dotfile symlinks"
            STOW_EXTRA_ARGS+=("-R")
            ;;
        -s | --strict)
            log_msg "strict mode enabled"
            set -e; 
            ;;
        -u | --user | --username)
            SETUP_USER="$2"
            SETUP_HOME_DIR="/home/$SETUP_USER"
            shift;
            ;;
        -d | --dry | --dry-run )
            DRY_RUN=true
            log_wrn "note: performing dry run"
            STOW_EXTRA_ARGS+=("--simulate")
            SETUP_SCRIPT_EXTRA_ARGS+=("--dry")
            ;;
        -h | --help)
            usage 0
            ;;
        --)
            shift;
            break
            ;;
        *)
            log_err "unknown option: $1"
            usage
            ;;
    esac
    shift;
done

# Check if install arg exists
if $SETUP_PACKAGES ; then
    if [ $# -eq 0 ]; then
        std_fat "missing install list(s) or entries to install"
    fi
fi

# Check username
if [ -z "$SETUP_USER" ]; then
    std_fat "cannot automatically detect user name - please provide one using the --username option"
fi

# Check home dir
if [ ! -d "$SETUP_HOME_DIR" ]; then
    std_fat "invalid home directory: $SETUP_HOME_DIR"
fi

if ! $SETUP_OVERRIDE ; then 
    SETUP_PACKAGES=false
    SETUP_DOTFILES=true
    SETUP_PATCHES=false
    SETUP_SERVICES=false
fi

log_msg "user: $SETUP_USER"
log_msg "home: $SETUP_HOME_DIR"
log_msg "list: $*"

export SETUP_USER
export SETUP_HOME_DIR


### Start setup

packages_requiring_linked_dotfiles=()
errored_entries=()

if $SETUP_PACKAGES ; then

    log_suc "Starting installations; Command: '${PM_INSTALL_CMD[*]}'"

    function process_list ()
    {
        local entry
        local to_include
        local to_post_install
        local SETUP_SCRIPT
        local AUR_PREFIX
        local pkg
        local script_rel_path
        local -a entries
        for entry in "$@"; do
            cd "install" || std_fat "failed to enter install directory"
            SETUP_SCRIPT="$entry"
            AUR_PREFIX="aur/"
            if [[ "$entry" == "+"* ]]; then
                cd "$DOTFILES_ROOT_DIR"
                to_include="include/${entry#"+"}"
                log_msg "Including list file   : $to_include"
                if [ -f "lists/$to_include" ]; then
                    mapfile -t entries < <(read_list "lists/$to_include")
                    process_list "${entries[@]}"
                else
                    log_err "Missing include list  : $to_include"
                    errored_entries+=("$entry")
                fi
            elif [[ "$entry" == "!"* ]]; then
                to_post_install=${entry#"!"}
                log_msg "Post-link install set : $to_post_install"
                mapfile -t entries < <(printf '%s\n' "$to_post_install" | tr '[:space:]' '\n' | sed '/^$/d')
                packages_requiring_linked_dotfiles+=("${entries[@]}")
            elif [ -f "$SETUP_SCRIPT" ]; then
                log_msg "Setting up via script : $SETUP_SCRIPT"
                script_rel_path=${SETUP_SCRIPT%*/}
                log_dbg "Script path: $script_rel_path"
                if ! $DRY_RUN ; then
                    # shellcheck source=/dev/null
                    if ! source ./"$script_rel_path"; then
                        log_err "Setup script failed : $SETUP_SCRIPT"
                        errored_entries+=("$entry")
                    fi
                fi
            elif [[ "$entry" == "$AUR_PREFIX"* ]]; then
                pkg=${entry#"$AUR_PREFIX"}
                log_msg "Installing from AUR   : $pkg"
                if ! $DRY_RUN ; then
                    if inst_aur "$pkg"; then
                        log_suc "Successfully installed: $pkg"
                    else
                        errored_entries+=("$entry")
                    fi
                fi
            else
                log_msg "Installing package    : $entry"
                if ! $DRY_RUN ; then
                    if inst "$entry"; then
                        log_suc "Successfully installed: $entry"
                    else
                        errored_entries+=("$entry")
                    fi
                fi
            fi
            cd "$DOTFILES_ROOT_DIR"
            if ! $DRY_RUN ; then
                sleep 1
            fi
        done
    }

    declare -a entries
    for arg in "$@" ; do
        entries=()
        if [[ "$arg" == "install/"* ]]; then
            log_msg "Ignoring install/ pfix: $arg"
            arg=${arg#"install/"}
        fi
        if [ -f "$arg" ]; then
            mapfile -t entries < <(read_list "$arg")
            process_list "${entries[@]}"
        else
            process_list "$arg"
        fi
    done

    log_suc "Installations finished."
fi


if $SETUP_DOTFILES ; then
    # Ensure .config dir exists so that it is not
    # symlinked (otherwise all programs would dump
    # their config into the dotfiles directory)
    backup_dir=/tmp/dotfiles
    if ! $DRY_RUN ; then
        mkdir -p "$SETUP_HOME_DIR/.config"

        # Force overwrites of specified files (save backup to /tmp)
        rm -rf "$backup_dir"
        mapfile -t force_overwrite_list < <(read_list ".link.force")
        for entry in "${force_overwrite_list[@]}"; do
            entry_path="$SETUP_HOME_DIR/$entry"
            if [[ -f $entry_path && ! -h $entry_path ]]; then
                mkdir -p "$backup_dir"
                log_msg "Forcing overwrite of: $entry_path ; backup at $backup_dir"
                mv "$entry_path" "$backup_dir"
            fi
        done
    fi

    cd dotfiles || std_fat "failed to enter dotfiles directory"
    if stow --no-folding "${STOW_EXTRA_ARGS[@]}" -v . -t "$SETUP_HOME_DIR" ; then
        log_suc "Dotfiles linked."
    else
        log_err "Failed linking dotfiles! Backup is kept at: $backup_dir"
        SETUP_FAILED=true
    fi
    cd "$DOTFILES_ROOT_DIR"
    
    unset backup_dir
    unset force_overwrite_list
fi

if $SETUP_PATCHES ; then
    patches_dir="patches"
    patches_script="patch"
    if [ -d "$patches_dir" ]; then
        cd "$patches_dir" || std_fat "failed to enter $patches_dir directory"
        if [ -f "$patches_script" ]; then
            # shellcheck source=/dev/null
            source ./"$patches_script" "${SETUP_SCRIPT_EXTRA_ARGS[@]}"
        else
            log_err "$patches_dir/$patches_script script is not present."
        fi
    else
        log_err "$patches_dir/ directory is not present."
    fi
    unset patches_dir
    unset patches_script
    cd "$DOTFILES_ROOT_DIR"
fi

if $SETUP_SERVICES ; then
    services_dir="systemd"
    services_script="setup_services"
    if [ -d "$services_dir" ]; then
        cd "$services_dir" || std_fat "failed to enter $services_dir directory"
        if [ -f "$services_script" ]; then
            # shellcheck source=/dev/null
            source ./"$services_script" "${SETUP_SCRIPT_EXTRA_ARGS[@]}"
        else
            log_err "$services_dir/$services_script script is not present."
        fi
    else
        log_err "$services_dir/ directory is not present."
    fi
    unset services_dir
    unset services_script
    cd "$DOTFILES_ROOT_DIR"
fi

if $SETUP_PACKAGES ; then
    process_list "${packages_requiring_linked_dotfiles[@]}"

    for errored_entry in "${errored_entries[@]}"; do
        log_err "Failed to install: $errored_entry"
    done
    if [ "${#errored_entries[@]}" -gt 0 ]; then
        SETUP_FAILED=true
    fi
fi

unset SETUP_USER
unset SETUP_HOME_DIR

if $SETUP_FAILED ; then
    log_err "Done with errors."
    exit 1
fi

log_suc "Done! Have a nice day."
