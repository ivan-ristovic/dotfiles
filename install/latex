#!/bin/bash

pkgs=(
    texlive-binextra
    texlive-latexextra 
    texlive-langextra 
    texlive-langcyrillic 
    texlive-luatex
    texlive-fontsextra 
    texlive-bibtexextra
    texlive-science
    texlive-xetex
)
inst "${pkgs[@]}" 
unset pkgs

log_msg "Compiling cyrillic fonts..."
if mktextfm larm1000 > /dev/null 2>&1 ; then
    log_suc "Successfully compiled cyrillic fonts"
else
    log_err "Failed to compile cyrillic fonts"
    log_err "Make sure to run mktextfm again manually"
fi

